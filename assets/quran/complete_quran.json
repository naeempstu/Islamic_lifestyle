      {"number": 2, "arabic": "الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ", "en": "All praise and thanks be to Allah, the Lord of the worlds", "bn": "সকল প্রশংসা ও কৃতজ্ঞতা আল্লাহর জন্য যিনি জগতসমূহের প্রতিপালক"},
      {"number": 3, "arabic": "الرَّحْمَـٰنِ الرَّحِيمِ", "en": "The Most Gracious, the Most Merciful", "bn": "যিনি অত্যন্ত দয়ালু ও ক্ষমাশীল"},
      {"number": 4, "arabic": "مَالِكِ يَوْمِ الدِّينِ", "en": "The Master of the Day of Judgment", "bn": "যিনি বিচার দিবসের মালিক"},
      {"number": 5, "arabic": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ", "en": "You alone we worship, and You alone we ask for help", "bn": "আমরা শুধু আপনার ইবাদত করি এবং শুধু আপনারই সাহায্য চাই"},
      {"number": 6, "arabic": "اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ", "en": "Guide us to the Straight Path", "bn": "আমাদের সরল পথ প্রদর্শন করুন"},
      {"number": 7, "arabic": "صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ", "en": "The path of those on whom You have bestowed Your Grace, not of those who have earned Your Anger, nor of those who have gone astray", "bn": "তাদের পথ যারা আপনার অনুগ্রহপ্রাপ্ত, না তাদের যারা আপনার ক্রোধের উর্দ্ধ্বে এবং না বিভ্রান্তদের"}
    ],
    "36": [
      {"number": 1, "arabic": "يس", "en": "Ya Seen", "bn": "সূরা ইয়া সিন"},
      {"number": 2, "arabic": "وَالْقُرْآنِ الْحَكِيمِ", "en": "By the wise Quran", "bn": "প্রজ্ঞাবান কুরআনের শপথ"}
    ],
    "55": [
      {"number": 1, "arabic": "الرَّحْمَـٰنُ", "en": "The Most Gracious", "bn": "দয়াবান"},
      {"number": 2, "arabic": "عَلَّمَ الْقُرْآنَ", "en": "He taught the Quran", "bn": "তিনি কুরআন শিখিয়েছেন"}
    ],
    "67": [
      {"number": 1, "arabic": "تَبَارَكَ الَّذِي بِيَدِهِ الْمُلْكُ وَهُوَ عَلَىٰ كُلِّ شَيْءٍ قَدِيرٌ", "en": "Blessed is He in Whose Hand is the dominion, and He is Able to do all things", "bn": "তিনি ধন্য যার হাতে রাজত্ব এবং তিনি সব কিছুর উপর ক্ষমতাশীল"}
    ],
    "112": [
      {"number": 1, "arabic": "قُلْ هُوَ اللَّهُ أَحَدٌ", "en": "Say: He is Allah, the One", "bn": "বলুন, তিনি আল্লাহ তিনি এক"},
      {"number": 2, "arabic": "اللَّهُ الصَّمَدُ", "en": "Allah is As-Samad", "bn": "আল্লাহ অমুখাপেক্ষী"},
      {"number": 3, "arabic": "لَمْ يَلِدْ وَلَمْ يُولَدْ", "en": "He begets not, nor is He begotten", "bn": "তিনি কোনো সন্তান জন্ম দেননি এবং তার কোনো সন্তান জন্মায়নি"},
      {"number": 4, "arabic": "وَلَمْ يَكُن لَّهُ كُفُوًا أَحَدٌ", "en": "And there is none equal to Him", "bn": "এবং তার মতো কোনো কিছু নেই"}
    ],
    "113": [
      {"number": 1, "arabic": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ", "en": "Say: I seek refuge with the Lord of the daybreak", "bn": "বলুন, আমি প্রার্থনা করি ঊষার প্রতিপালকের কাছে"},
      {"number": 2, "arabic": "مِن شَرِّ مَا خَلَقَ", "en": "From the evil of what He has created", "bn": "তিনি যা সৃষ্টি করেছেন তার অনিষ্ট থেকে"},
      {"number": 3, "arabic": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ", "en": "And from the evil of the darkness when it is intensified", "bn": "এবং রাতের অন্ধকারের অনিষ্ট থেকে যখন তা ঘনীয়ূত হয়"},
      {"number": 4, "arabic": "وَمِن شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ", "en": "And from the evil of those who blow on knots", "bn": "এবং যারা গিঁটে ফুঁক দেয় তাদের অনিষ্ট থেকে"},
      {"number": 5, "arabic": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ", "en": "And from the evil of the envious when he envies", "bn": "এবং ঈর্ষান্বিতের অনিষ্ট থেকে যখন সে ঈর্ষা করে"}
    ],
    "114": [
      {"number": 1, "arabic": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ", "en": "Say: I seek refuge with the Lord of mankind", "bn": "বলুন, আমি প্রার্থনা করি মানুষের প্রতিপালকের কাছে"},
      {"number": 2, "arabic": "مَلِكِ النَّاسِ", "en": "The King of mankind", "bn": "মানুষের রাজা"},
      {"number": 3, "arabic": "إِلَـٰهِ النَّاسِ", "en": "The Lord of mankind", "bn": "মানুষের উপাস্য"},
      {"number": 4, "arabic": "مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ", "en": "From the evil of the whisperer who withdraws", "bn": "কুঁজো কুসুমসা করার অনিষ্ট থেকে"},
      {"number": 5, "arabic": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ", "en": "Who whispers in the breasts of mankind", "bn": "যে মানুষের হৃদয়ে কুসুমসা করে"},
      {"number": 6, "arabic": "مِنَ الْجِنَّةِ وَالنَّاسِ", "en": "From the jinn and mankind", "bn": "জিন এবং মানুষদের মধ্য থেকে"}
    ]
  }
}
